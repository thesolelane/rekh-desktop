{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["main.js", "preload.js", "renderer/**/*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "build", "_*.js"]
}
