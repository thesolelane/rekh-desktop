{
  "name": "rekh-browser",
  "version": "0.1.0",
  "description": "REKH — a quiet, knowledge-focused browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "lint": "eslint ."
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.39.5",
    "globals": "^17.7.0"
  },
  "build": {
    "appId": "com.rekh.browser",
    "productName": "REKH",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icon.png"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "thesolelane",
        "repo": "rekh-desktop"
      }
    ]
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.0",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.1.7"
  }
}
